  "steps": [
    {
      "step_no": 1,
      "instruction": "Wash and soak basmati rice for 30 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Soak saffron in hot milk or water for 10 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Boil water with cinnamon, cloves, bay leaf, cardamom, salt, and ghee; add soaked rice and parboil, then drain.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Mix parboiled potato cubes with ginger-garlic paste, red chilli powder, turmeric, garam masala, and curd; marinate for 10 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Heat oil and butter in a pan; add green cardamom, fennel seeds, cinnamon, cloves, and bay leaves; sauté.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add marinated potatoes and cook for 5 minutes; reserve 1 cup of the potato masala.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Layer parboiled rice, fried onion, saffron milk, mint-coriander leaves, food colour, potato masala, and sautéed carrot in the pot.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Cover with aluminium foil, place on a hot iron dosa tawa, and cook on low flame for 25 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Remove from heat and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use fresh mint and coriander for maximum aroma in the dum process.",
    "Avoid over-stirring the layers to keep the rice grains intact.",
    "Serve immediately after dum cooking for the best texture and fragrance."
  ],
