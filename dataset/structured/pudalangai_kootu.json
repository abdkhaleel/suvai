  "steps": [
    {
      "step_no": 1,
      "instruction": "Rinse moong dal and pressure cook with ¾ cup water and turmeric powder for 2-3 whistles until soft. Mash lightly and set aside.",
      "tip": "",
      "duration_mins": 5
    },
    {
      "step_no": 2,
      "instruction": "Wash, peel the outer skin of snake gourd, remove the inner seeds and chop into small pieces.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "In a pan or pressure cooker, add chopped pudalangai, little water and cook until soft (2 whistles if using pressure cooker).",
      "tip": "",
      "duration_mins": 5
    },
    {
      "step_no": 4,
      "instruction": "Grind grated coconut, green chilli and cumin seeds into a smooth paste with little water.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add the cooked moong dal and ground coconut paste to the cooked snake gourd. Mix gently.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add salt and simmer for 3-4 minutes until the kootu thickens slightly.",
      "tip": "",
      "duration_mins": 4
    },
    {
      "step_no": 7,
      "instruction": "Heat oil in a small tadka pan. Add mustard seeds and let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Add urad dal and fry till golden. Add curry leaves and asafoetida. Pour this tempering over the kootu.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Mix well and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Choose tender snake gourd for better taste.",
    "Do not add too much water while cooking the vegetable.",
    "You can add a pinch of jaggery for a mild sweetness (optional).",
    "This kootu tastes best when served warm with rice."
  ],
