  "steps": [
    {
      "step_no": 1,
      "instruction": "Heat 1 tsp oil in a small pan. Add fennel seeds, cinnamon, cloves, cardamom, black pepper, and cumin seeds. Roast for a few seconds.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Add 10 peeled shallots and sauté for 1 minute. Cool and grind to a smooth paste. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Grind grated coconut and poppy seeds with little water into a smooth paste. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Heat gingelly oil in a wide pot or kadai. Add chopped shallots and curry leaves. Sauté for 2-3 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add ginger garlic paste and sauté until raw smell goes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add chopped tomatoes and cook until mushy.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add turmeric powder, red chilli powder, coriander powder, and salt. Mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Add cleaned nattu kozhi pieces and stir fry for 4-5 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Add enough water to cover the chicken and tamarind extract. Bring to a full boil.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Cover and simmer on low to medium heat for 60-90 minutes until chicken is tender.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 11,
      "instruction": "Add the freshly ground masala paste and coconut paste. Mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 12,
      "instruction": "Simmer on low heat for another 10-15 minutes until oil floats on top.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 13,
      "instruction": "Garnish with chopped coriander leaves and remove from heat.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use gingelly oil for authentic village-style flavour and aroma.",
    "Country chicken takes longer to cook than broiler chicken — pressure cooker can reduce time.",
    "Adjust spice level according to your preference.",
    "This kuzhambu tastes even better the next day as flavours develop."
