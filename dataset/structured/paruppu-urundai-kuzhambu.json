  "steps": [
    {
      "step_no": 1,
      "instruction": "Soak chana dal in water for 2 hours. Drain and grind to a coarse paste without adding water.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "To the ground dal, add fennel seeds, minced garlic, chopped onion, turmeric powder, green chilli, coriander leaves, grated coconut, and salt. Mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Shape into small dumplings and steam in an idli vessel for 5 minutes. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Heat oil in a wide flat pan. Add cloves, cinnamon, fennel seeds, curry leaves, and crushed garlic. Sauté until garlic turns golden.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add chopped onion and sauté until soft.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add pureed tomatoes, salt, turmeric powder, and sambar powder. Cook until oil separates.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Grind ¼ cup coconut with ½ cup water into a smooth paste and add to the pan.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Add 2 cups water and bring to a full boil. Check seasoning.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Gently add the steamed dumplings one by one. Do not stir for the first 5 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Simmer on medium heat for 10-12 minutes. Turn dumplings gently if needed. Remove from heat.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use a wide flat pan instead of a kadai to prevent dumplings from breaking.",
    "Do not stir immediately after adding dumplings to avoid breaking them.",
    "Steam the dumplings only for 5 minutes so they remain soft.",
    "This kuzhambu tastes even better the next day as the flavours develop."
  ],
