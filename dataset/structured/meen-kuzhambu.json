  "steps": [
    {
      "step_no": 1,
      "instruction": "Soak tamarind in 1 cup warm water for 15 minutes. Extract juice and discard pulp. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Grind grated coconut, fennel seeds, shallots, and garlic into a smooth paste. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Heat gingelly oil in a wide pan or earthen pot. Add mustard seeds and fenugreek seeds. Let them splutter.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add curry leaves, chopped shallots, and crushed garlic. Sauté until shallots turn golden.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add chopped tomatoes and cook until soft and mushy.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add turmeric powder, red chilli powder, coriander powder, and salt. Mix well and fry for a minute.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add the extracted tamarind water and bring to a boil.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Add the ground coconut masala paste and mix well. Simmer for 5 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Gently add the cleaned fish pieces. Do not stir too much to avoid breaking the fish.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Cover and simmer on medium-low heat for 10-12 minutes until fish is cooked and oil floats on top.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 11,
      "instruction": "Check seasoning and adjust if needed. Remove from heat.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use gingelly oil for authentic taste and aroma.",
    "Do not overcook the fish — it will become tough.",
    "Allow the kuzhambu to rest for 15-20 minutes before serving for better flavour.",
    "This kuzhambu tastes even better the next day."
  ],
