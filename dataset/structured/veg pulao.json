  "steps": [
    {
      "step_no": 1,
      "instruction": "Wash basmati rice 2-3 times and soak for 15 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Coarsely grind green chilli, ginger, garlic, mint, and coriander leaves.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Heat oil and ghee in a pressure cooker; add whole spices and sauté.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add sliced onion and sauté till light brown.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add ground paste, mixed vegetables, and sauté for 3 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add chopped tomato, garam masala, red chilli powder, and turmeric; sauté till soft.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add soaked rice, salt, and water; mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Cover and cook for 3-4 whistles (or 10 minutes in open pan).",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "For raita, mix curd with pomegranate arils, salt, ginger, green chilli, mint, roasted cumin, and red chilli powder.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Fluff the pulao and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Soak rice properly to get non-sticky grains.",
    "Do not overcook vegetables to retain crunch.",
    "Prepare raita fresh and chill before serving for best taste."
