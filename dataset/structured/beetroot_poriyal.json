  "total_time": 30,
  "servings": 3,
  "ingredients": [
    {
      "name": "Beetroot",
      "tamil_name": "பீட்ரூட்",
      "transliteration": "Beetroot",
      "quantity": 2,
      "unit": "medium",
      "notes": "250-300 grams"
    },
    {
      "name": "Gingelly oil",
      "tamil_name": "நல்லெண்ணெய்",
      "transliteration": "Nallennai",
      "quantity": 2,
      "unit": "tbsp",
      "notes": "or coconut oil"
    },
    {
      "name": "Mustard seeds",
      "tamil_name": "கடுகு",
      "transliteration": "Katugu",
      "quantity": 1,
      "unit": "tsp",
      "notes": ""
    },
    {
      "name": "Urad dal",
      "tamil_name": "உளுந்து பருப்பு",
      "transliteration": "Urad Paruppu",
      "quantity": 1,
      "unit": "tsp",
      "notes": ""
    },
    {
      "name": "Green chilli",
      "tamil_name": "பச்சை மிளகாய்",
      "transliteration": "Pachai Milagai",
      "quantity": 1,
      "unit": "whole",
      "notes": "chopped"
    },
    {
      "name": "Curry leaves",
      "tamil_name": "கறிவேப்பிலை",
      "transliteration": "Kariveppilai",
      "quantity": 1,
      "unit": "sprig",
      "notes": ""
    },
    {
      "name": "Turmeric powder",
      "tamil_name": "மஞ்சள் தூள்",
      "transliteration": "Manjal Thool",
      "quantity": 0.25,
      "unit": "tsp",
      "notes": ""
    },
    {
      "name": "Asafoetida",
      "tamil_name": "பெருங்காயம்",
      "transliteration": "Perungayam",
      "quantity": 1,
      "unit": "pinch",
      "notes": ""
    },
    {
      "name": "Grated coconut",
      "tamil_name": "தேங்காய் துருவல்",
      "transliteration": "Thengai Thuruval",
      "quantity": 0.33,
      "unit": "cup",
      "notes": ""
    },
    {
      "name": "Salt",
      "tamil_name": "உப்பு",
      "transliteration": "Uppu",
      "quantity": 1,
      "unit": "to taste",
      "notes": ""
    },
    {
      "name": "Water",
      "tamil_name": "தண்ணீர்",
      "transliteration": "Tannir",
      "quantity": 0.33,
      "unit": "cup",
      "notes": "as needed"
    }
  ],
  "steps": [
    {
      "step_no": 1,
      "instruction": "Peel and finely chop the beetroots into small cubes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Heat oil in a kadai. Add mustard seeds and let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Add urad dal and fry until golden brown.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add chopped green chilli and curry leaves. Sauté for a few seconds.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add chopped beetroot, turmeric powder, asafoetida, and salt. Mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Sprinkle water, cover and cook on low-medium heat until beetroot is tender (stir occasionally).",
      "tip": "",
      "duration_mins": 10
    },
    {
      "step_no": 7,
      "instruction": "Once cooked and water evaporates, add grated coconut.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Mix thoroughly and cook for 2 minutes on low heat.",
      "tip": "",
      "duration_mins": 2
    },
    {
      "step_no": 9,
      "instruction": "Remove from heat and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Chop beetroot into small uniform pieces for even and faster cooking.",
    "Adjust water carefully — beetroot releases some moisture while cooking.",
    "Fresh grated coconut gives the best flavour and texture.",
    "You can add a pinch of sugar or jaggery for extra mild sweetness."
  ],
  "variations": [
