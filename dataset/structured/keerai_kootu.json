  "steps": [
    {
      "step_no": 1,
      "instruction": "Rinse moong dal well and pressure cook with ¾ to 1 cup water until soft and mushy (3 whistles). Mash well and set aside.",
      "tip": "",
      "duration_mins": 5
    },
    {
      "step_no": 2,
      "instruction": "Grind grated coconut with ¼ cup water into a smooth paste. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Heat ghee or oil in a pan. Add mustard seeds, cumin seeds and broken red chilli. Let them splutter.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add chopped garlic, curry leaves, green chilli and asafoetida. Sauté for a minute.",
      "tip": "",
      "duration_mins": 1
    },
    {
      "step_no": 5,
      "instruction": "Add chopped onion and a pinch of salt. Sauté until onions turn soft and translucent.",
      "tip": "",
      "duration_mins": 3
    },
    {
      "step_no": 6,
      "instruction": "Add chopped tomato and cook until soft and mushy.",
      "tip": "",
      "duration_mins": 2
    },
    {
      "step_no": 7,
      "instruction": "Add turmeric powder, red chilli powder, coriander powder and cumin powder. Sauté for 1 minute.",
      "tip": "",
      "duration_mins": 1
    },
    {
      "step_no": 8,
      "instruction": "Add chopped keerai (spinach) and cook until wilted (4-5 minutes).",
      "tip": "",
      "duration_mins": 5
    },
    {
      "step_no": 9,
      "instruction": "Add the mashed dal and coconut paste. Mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Add hot water as needed to adjust consistency. Simmer for 3-4 minutes until bubbling hot. Adjust salt.",
      "tip": "",
      "duration_mins": 4
    },
    {
      "step_no": 11,
      "instruction": "Remove from heat and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use fresh tender spinach for bright green colour and best taste.",
    "Do not overcook the greens after adding dal to retain texture and colour.",
    "This kootu thickens as it cools, so keep it slightly loose.",
    "For vegan version, use oil instead of ghee."
  ],
