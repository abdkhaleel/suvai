"steps": [
{
"step_no": 1,
"instruction": "Rinse and soak urad dal, chana dal and fenugreek seeds in 1 cup water for 4-5 hours.",
"tip": "",
"duration_mins": 300
},
{
"step_no": 2,
"instruction": "Rinse rice and poha. Soak together in 2 cups water for 4-5 hours.",
"tip": "",
"duration_mins": 300
},
{
"step_no": 3,
"instruction": "Grind soaked lentils with ½ cup water to a fluffy batter.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 4,
"instruction": "Grind soaked rice and poha with 1 cup water to fine grainy consistency.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 5,
"instruction": "Mix both batters, add salt and ferment for 8-9 hours or overnight.",
"tip": "",
"duration_mins": 540
},
{
"step_no": 6,
"instruction": "Prepare potato masala: Boil potatoes, peel and crumble.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 7,
"instruction": "Heat oil, fry mustard seeds, chana dal, onions, ginger, green chillies, curry leaves.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 8,
"instruction": "Add turmeric, hing, water, potatoes, salt and cook till thickened.",
"tip": "",
"duration_mins": 5
},
{
"step_no": 9,
"instruction": "Heat tawa, spread dosa batter thinly, drizzle oil and cook till crisp.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 10,
"instruction": "Place potato masala in center, fold and serve hot.",
"tip": "",
"duration_mins": 0
}
],
