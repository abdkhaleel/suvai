  "steps": [
    {
      "step_no": 1,
      "instruction": "Soak tamarind and jaggery in ½ cup water. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Heat 1½ tbsp oil in a pan. Add chana dal, urad dal, peanuts and dried red chillies.",
      "tip": "Keep the flame medium while sautéing onions to prevent lentils from burning.",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Fry on medium heat, stirring often, until lightly golden and aromatic.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add garlic and cubed onions. Fry for 3 to 4 minutes until onions are half done.",
      "tip": "",
      "duration_mins": 4
    },
    {
      "step_no": 5,
      "instruction": "Add cumin seeds and curry leaves. Sauté until onions are light golden and soft.",
      "tip": "Sautéing the onions well until they lose raw flavour and begin to caramelize is the key step.",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Cool completely. Transfer to a blender jar along with salt.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Squeeze soaked tamarind and filter through a small sieve. Add to the blender.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Blend until smooth, adding more water as needed to reach desired consistency.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Taste test and adjust salt. Transfer to a serving bowl.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "For tempering, heat ½ tbsp oil. Add mustard seeds, urad dal and dried red chilli.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 11,
      "instruction": "When dal turns light golden, add curry leaves and asafoetida. Turn off heat.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 12,
      "instruction": "Pour tempering over the chutney and mix well. Serve with idli, dosa or snacks.",
      "tip": "This chutney can be stored in the fridge for up to 48 hours.",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Sautéing the onions well until they lose raw flavour and begin to caramelize is the key step.",
    "Use shallots for a more traditional and sweeter flavour.",
    "Do not reduce oil — onions need enough oil to fry well and develop flavour.",
    "Keep the flame medium while sautéing onions to prevent lentils from burning.",
    "This chutney can be stored in the fridge for up to 48 hours.",
    "You can add coriander leaves or mint leaves after frying onions for a fresh twist."
  ],
