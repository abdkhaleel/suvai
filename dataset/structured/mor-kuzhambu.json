  "steps": [
    {
      "step_no": 1,
      "instruction": "Rinse tuvar dal, coriander seeds, cumin seeds, and raw rice. Soak in ¼ cup hot water for 20 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Add soaked ingredients along with green chillies, ginger, curry leaves, and grated coconut into a mixer jar. Grind to a smooth paste.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Whisk the thick sour curd until smooth. Add the ground paste and 1 cup water. Mix well and set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Peel and chop ash gourd into cubes. Cook with 1 cup water and turmeric powder until almost tender.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Reduce heat to low, add the buttermilk mixture and salt. Mix gently.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Simmer on low heat until the kuzhambu turns frothy and comes to a gentle boil. Do not let it boil vigorously. Turn off the heat.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Heat oil in a small pan. Add mustard seeds and let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Add fenugreek seeds, dried red chillies, curry leaves, and asafoetida. Fry briefly.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Pour the tempering over the mor kuzhambu. Cover and let it rest for 5 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Serve hot with steamed rice.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use slightly sour, full-fat curd for the best taste and to prevent curdling.",
    "Do not boil the kuzhambu after adding the curd mixture — only gentle simmer is needed.",
    "Rice or rice flour in the paste helps thicken the gravy and prevents separation.",
    "You can skip ash gourd or use other vegetables like okra, brinjal, or drumstick."
  ],
