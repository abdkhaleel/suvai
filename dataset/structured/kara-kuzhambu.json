  "steps": [
    {
      "step_no": 1,
      "instruction": "Heat 1 tsp sesame oil in a pan. Add fenugreek seeds, coriander seeds, fennel seeds, and dried red chillies. Fry until aromatic.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Add grated coconut and fry for a couple of minutes. Switch off the flame.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Add sambar powder and ½ tsp salt. Mix well and let it cool.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Grind the cooled mixture with ½ cup water into a smooth paste. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Heat 3 tbsp sesame oil in a pressure cooker or pan. Add mustard seeds and curry leaves. Let them splutter.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add chopped onion and sauté until soft. Add chopped tomato and cook until juicy.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add chopped drumstick and brinjal. Add ½ cup water, ground masala paste, tamarind paste, remaining salt, and jaggery.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Mix gently, cover and pressure cook for 2 whistles (or simmer on low flame for 15 minutes if not using cooker).",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Once pressure releases, open and check consistency. Add hot water if needed to get a pouring consistency.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Mix well and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use generous sesame oil for authentic taste and to prevent bitterness from fenugreek.",
    "Do not over-roast fenugreek seeds as they can make the gravy bitter.",
    "Adjust water after cooking to get the right gravy consistency.",
    "This kuzhambu tastes better the next day as flavours develop."
  ],
