  "steps": [
    {
      "step_no": 1,
      "instruction": "Mix tamarind pulp with ½ cup water and set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Dry roast fennel seeds, cumin seeds, fenugreek seeds, black peppercorns, and mustard seeds until aromatic. Cool and grind to a coarse powder. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Heat gingelly oil in a kadai. Add mustard seeds, cumin seeds, fenugreek seeds, dry red chillies, and curry leaves. Let them sizzle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add finely chopped onions, green chillies, salt, and turmeric powder. Sauté until onions turn golden.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add ginger garlic paste and sauté until raw smell disappears.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add red chilli powder and coriander powder. Fry for 2-3 minutes until fragrant.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add tomato puree and cook until oil separates and mixture thickens.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Pour in tamarind water and mix well. Cook until the masala thickens and oil floats on top.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Add cleaned prawns and stir fry on high heat for 4-5 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Cover and cook for 6-8 minutes until prawns are cooked through.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 11,
      "instruction": "Sprinkle the roasted special powder, garam masala powder, jaggery, and chopped coriander leaves. Mix gently.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 12,
      "instruction": "Remove from heat and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use gingelly oil for authentic taste and flavour.",
    "Cook the masala base patiently until oil separates for best results.",
    "Do not overcook prawns as they become rubbery.",
    "This thokku tastes even better the next day."
  ],
