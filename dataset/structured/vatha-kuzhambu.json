      "transliteration": "புளி",
      "quantity": "1",
      "unit": "lemon sized ball",
      "notes": "or 1 tbsp tightly packed"
    },
    {
      "name": "Hot water for soaking",
      "tamil_name": "தண்ணீர்",
      "transliteration": "தண்ணீர்",
      "quantity": "1",
      "unit": "cup",
      "notes": ""
    },
    {
      "name": "Gingelly oil",
      "tamil_name": "நல்லெண்ணெய்",
      "transliteration": "நல்லெண்ணெய்",
      "quantity": "3",
      "unit": "tbsp",
      "notes": ""
    },
    {
      "name": "Mustard seeds",
      "tamil_name": "கடுகு",
      "transliteration": "கடுகு",
      "quantity": "1/2",
      "unit": "tsp",
      "notes": ""
    },
    {
      "name": "Fenugreek seeds",
      "tamil_name": "வெந்தயம்",
      "transliteration": "வெந்தயம்",
      "quantity": "1/2",
      "unit": "tsp",
      "notes": ""
    },
    {
