      "unit": "tsp",
      "notes": "optional"
    },
    {
      "name": "Jaggery",
      "tamil_name": "வெல்லம்",
      "transliteration": "வெல்லம்",
      "quantity": "1/2",
      "unit": "tsp",
      "notes": "optional"
    }
  ],
  "steps": [
    {
      "step_no": 1,
      "instruction": "Soak tamarind in 1 cup hot water for 20-30 minutes. Squeeze and extract the pulp. Keep aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Heat gingelly oil in a pan. Add mustard seeds and let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Add fenugreek seeds, broken red chillies, curry leaves, and asafoetida. Fry on low heat until chillies change color.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add manathakkali vathal and fry on low heat for a few seconds until the color changes slightly. Do not burn.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Switch off the heat and add sambar powder. Stir for 1 minute (you can keep on low heat briefly).",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add the extracted tamarind pulp and 2 cups water. Stir well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add salt to taste and bring to a boil on medium-low heat.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Simmer for 25-30 minutes until the gravy thickens slightly and oil specks appear on top.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Add rice flour and jaggery (if using). Simmer for another 4-5 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Switch off the heat. Let it rest for a few minutes so a layer of oil forms on top. Check seasoning.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use generous amount of gingelly oil for authentic taste and longer shelf life.",
    "Fry the vathal and sambar powder on low heat to avoid burning.",
    "Aged dark tamarind gives better sourness to the kuzhambu.",
    "This kuzhambu tastes even better the next day as flavors develop."
  ],
  "variations": [
    "Sundakkai vatha kuzhambu",
    "Mixed vegetable vatha kuzhambu",
    "No vathal version with brinjal or drumstick"
  ],
