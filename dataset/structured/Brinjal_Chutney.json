  "steps": [
    {
      "step_no": 1,
      "instruction": "Heat 1 tsp oil in a pan. Add urad dal, dry red chillies and garlic. Fry for a minute until fragrant.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Transfer to a blender, add some water and grind to a smooth paste. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "In the same pan, add chopped brinjal. Sauté well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add salt and turmeric powder. Mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add water and tamarind pulp. Cook until the brinjal is completely done and soft.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Transfer the cooked brinjal to a blender. Add jaggery and the ground dal-chilli-garlic paste.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Puree everything together until smooth. Transfer to a bowl.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "For tempering, heat 3 tbsp gingelly oil in the same pan. Add mustard seeds and let them splutter.",
      "tip": "Use gingelly oil for the most authentic flavour.",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Add split urad dal, asafoetida and curry leaves. Fry until dal is golden and leaves are crisp.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Add the ground chutney to the tempering and mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 11,
      "instruction": "Serve hot with idli, dosa or rice.",
      "tip": "This chutney is best consumed fresh and may not store well for more than a day.",
      "duration_mins": 0
    }
  ],
  "tips": [
    "You can use any variety of brinjal or eggplant. Green brinjal works very well.",
    "Use gingelly oil for the most authentic flavour.",
    "Instead of tamarind pulp, you can use a small piece of tamarind while grinding.",
    "Adjust dry red chillies as per your spice level.",
    "The smoky version (roasting brinjal over direct flame) gives a unique flavour but is optional.",
    "This chutney is best consumed fresh and may not store well for more than a day."
  ],
