  "steps": [
    {
      "step_no": 1,
      "instruction": "Heat gingelly oil in a kadai or pan on low heat. Add mustard seeds and let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Add urad dal and fry until golden, stirring continuously to prevent burning.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Add chopped green chilli and curry leaves. Sauté for a few seconds.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add finely chopped carrots, turmeric powder, asafoetida, and salt. Mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add ½ cup water and stir. Cover and cook on low heat until carrots are tender.",
      "tip": "",
      "duration_mins": 10
    },
    {
      "step_no": 6,
      "instruction": "Check every 4-5 minutes and add more water if needed.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Once carrots are cooked and water evaporates, add grated coconut.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Mix thoroughly and cook for 1-2 minutes. Remove from heat.",
      "tip": "",
      "duration_mins": 2
    },
    {
      "step_no": 9,
      "instruction": "Serve hot or warm. Garnish with chopped coriander leaves if desired.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Finely chop the carrots for faster and even cooking.",
    "Use fresh tender carrots for best taste and colour.",
    "Do not add too much water to keep the poriyal dry.",
    "You can use coconut oil for a more authentic flavour."
  ],
