"steps": [
{"step_no": 1, "instruction": "Mix rava with ½ cup water. Rest for 20 to 30 minutes.", "tip": "", "duration_mins": 30},
{"step_no": 2, "instruction": "Chop onion, tomato and green chili. Mix veggies and keep aside.", "tip": "", "duration_mins": 0},
{"step_no": 3, "instruction": "After resting, adjust consistency if needed. Add lemon juice and salt. Mix well.", "tip": "", "duration_mins": 0},
{"step_no": 4, "instruction": "Add baking soda or eno and mix gently.", "tip": "", "duration_mins": 0},
{"step_no": 5, "instruction": "Heat tawa, grease with oil. Pour batter and spread gently.", "tip": "", "duration_mins": 0},
{"step_no": 6, "instruction": "Top with mixed veggies while batter is still raw. Press lightly and drizzle oil.", "tip": "", "duration_mins": 0},
{"step_no": 7, "instruction": "Cook till base is browned, flip and cook veggie side till golden.", "tip": "", "duration_mins": 0},
{"step_no": 8, "instruction": "Serve hot.", "tip": "", "duration_mins": 0}
