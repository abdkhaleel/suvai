"steps": [
{
"step_no": 1,
"instruction": "Roast moong dal on low heat till aromatic.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 2,
"instruction": "Pressure cook roasted moong dal with ¾ cup water. Mash and keep aside.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 3,
"instruction": "Roast ½ cup rava on low heat till fragrant.",
"tip": "",
"duration_mins": 8
},
{
"step_no": 4,
"instruction": "Heat 3 tablespoons ghee. Add cumin seeds, cashews, curry leaves, ginger and black pepper.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 5,
"instruction": "Pour 1.5 cups water and bring to a rolling boil.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 6,
"instruction": "Add roasted rava in batches, stirring continuously.",
"tip": "",
"duration_mins": 0
},
{
"step_no": 7,
"instruction": "Add mashed moong dal and salt. Simmer till thickened.",
"tip": "",
"duration_mins": 0
}
],
