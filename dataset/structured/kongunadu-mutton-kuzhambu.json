  "steps": [
    {
      "step_no": 1,
      "instruction": "Heat 1 tbsp gingelly oil in a pan. Add all masala paste ingredients except onions and tomatoes. Roast on low flame for 4-5 minutes until fragrant. Set aside to cool.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "In the same pan, add remaining oil, chopped onions and sauté until soft. Add tomatoes and cook until mushy. Remove and cool.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Grind the roasted spices, onions, tomatoes, and a little water into a smooth fine paste. Set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Heat 1 tbsp gingelly oil in a pressure cooker. Add curry leaves and chopped shallots. Sauté briefly.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add cleaned mutton pieces, castor oil (optional), and cook on medium heat for 5 minutes until juices evaporate.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add turmeric powder and mix well. Add the prepared masala paste.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Rinse the mixer jar with 1 cup water and add it to the cooker. Add 1.5 cups water.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Pressure cook for 30 minutes on medium heat. Let the pressure release naturally.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Open the cooker, add salt and 1 cup thick coconut milk. Simmer on low heat for 5-7 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Remove from heat and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Do not trim fat from mutton as it enhances flavour and richness.",
    "Roast spices on low flame to prevent burning and bitterness.",
    "Add salt only at the end for softer mutton pieces.",
    "This kuzhambu tastes even better the next day after flavours meld."
  ],
