  "steps": [
    {
      "step_no": 1,
      "instruction": "Wash and soak basmati rice for 30 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Wash and soak chickpeas for 8 hours; boil with salt, turmeric, and red chilli powder till soft.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Grind mint leaves, coriander leaves, and green chilli coarsely.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Heat oil and butter in a pressure cooker; add whole spices and sauté.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add sliced onion and sauté till light brown.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add ginger-garlic paste and sauté.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add mint-coriander-green chilli mixture and sauté.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Add chopped tomato and cook till soft.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Add boiled chickpeas, garam masala, and red chilli powder; mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Add salt and water; bring to a boil.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 11,
      "instruction": "Add soaked rice, mix gently, cover, and cook for 3-4 whistles.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 12,
      "instruction": "Sprinkle fresh mint leaves and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Soak chickpeas well for soft texture in the biryani.",
    "Mix rice gently after adding to avoid breaking grains.",
    "Use pineapple raita for a sweet contrast to the spicy biryani."
