  "steps": [
    {
      "step_no": 1,
      "instruction": "Wash, peel and chop chow chow into small cubes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "In a small pressure cooker, add chana dal at the bottom and add water just enough to cover the dal.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Place the chopped chow chow pieces over the dal. Add turmeric powder.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Pressure cook for 2 to 3 whistles. Let the pressure release naturally.",
      "tip": "",
      "duration_mins": 5
    },
    {
      "step_no": 5,
      "instruction": "Meanwhile, grind grated coconut, green chilli and cumin seeds into a smooth paste with very little water.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Open the cooker and place it back on low heat. Add salt and bring to a gentle boil.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add the ground coconut paste and mix gently without breaking the vegetable pieces.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Let it come to a gentle boil and switch off the heat.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Heat coconut oil in a small pan. Add mustard seeds, let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Add urad dal and fry till golden. Add curry leaves and pour the tempering over the kootu. Mix well.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Do not add too much water while pressure cooking to avoid a watery kootu.",
    "If the kootu is watery, boil on high heat for a few minutes without lid or add a little raw rice while grinding the coconut paste.",
    "Adding a pinch of jaggery enhances the taste (optional).",
    "Use coconut oil for authentic flavour."
  ],
