  "steps": [
    {
      "step_no": 1,
      "instruction": "Rinse moong dal and pressure cook with ¾ cup water and turmeric powder for 2-3 whistles until soft. Mash lightly and keep aside.",
      "tip": "",
      "duration_mins": 5
    },
    {
      "step_no": 2,
      "instruction": "Chop all vegetables into small cubes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "In a pan, add the chopped vegetables with little water and salt. Cook until vegetables are soft but not mushy.",
      "tip": "",
      "duration_mins": 8
    },
    {
      "step_no": 4,
      "instruction": "Dry roast dried red chillies, black pepper, cumin seeds and raw rice until aromatic. Cool slightly.",
      "tip": "",
      "duration_mins": 2
    },
    {
      "step_no": 5,
      "instruction": "Grind the roasted ingredients along with grated coconut into a coarse paste. Add very little water if needed.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add the cooked moong dal and ground coconut paste to the cooked vegetables. Mix gently.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Simmer on low heat for 3-4 minutes until everything is well combined. Adjust consistency if needed.",
      "tip": "",
      "duration_mins": 4
    },
    {
      "step_no": 8,
      "instruction": "Heat oil in a small tadka pan. Add mustard seeds, let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Add urad dal and fry until golden. Add curry leaves and asafoetida. Pour this tempering over the kootu.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Mix well and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use a mix of vegetables for better taste and nutrition.",
    "Do not add too much water while cooking vegetables to keep the kootu dry.",
    "Roast the spices on low flame to avoid burning.",
    "This kootu tastes best when served slightly warm."
  ],
