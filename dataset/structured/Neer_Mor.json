  "steps": [
    {
      "step_no": 1,
      "instruction": "To a mixing bowl, add 1 cup fresh thick curd.",
      "tip": "Use fresh thick curd that is not sour for the best taste.",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Add 2½ cups chilled water. Whisk vigorously using a hand churner or whisk until nice and frothy. You can also use a mixie with churner attachment.",
      "tip": "Neer Mor is meant to be watery — adjust water quantity as per your liking.",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Add cumin seeds (you can crush them for more flavour), finely chopped green chilli, ginger, coriander leaves and salt.",
      "tip": "You can add raw cumin seeds or use them for tempering along with other ingredients.",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Mix everything well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "For tempering, heat ½ tsp oil in a small pan. Add mustard seeds and let them splutter.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add curry leaves and asafoetida. Fry for a few seconds until leaves are crisp.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Pour the tempering into the buttermilk and mix well.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Serve chilled or at room temperature. You can strain before serving if preferred.",
      "tip": "Neer Mor is best consumed fresh, but can be refrigerated for up to 2 days.",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use fresh thick curd that is not sour for the best taste.",
    "Neer Mor is meant to be watery — adjust water quantity as per your liking.",
