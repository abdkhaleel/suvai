  "steps": [
    {
      "step_no": 1,
      "instruction": "Wash and trim both ends of the beans. Chop them into small pieces.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "Heat oil in a pan or kadai. Add mustard seeds and let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Add urad dal and fry until golden brown.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Add broken red chilli, curry leaves, and asafoetida. Sauté for a few seconds.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add chopped beans and sauté for 1 minute.",
      "tip": "",
      "duration_mins": 1
    },
    {
      "step_no": 6,
      "instruction": "Sprinkle little water, cover and cook on medium-low flame until beans are soft (stir occasionally).",
      "tip": "",
      "duration_mins": 8
    },
    {
      "step_no": 7,
      "instruction": "Add salt and mix well. Cook for another 2 minutes.",
      "tip": "",
      "duration_mins": 2
    },
    {
      "step_no": 8,
      "instruction": "Add grated coconut and mix thoroughly. Cook for 1-2 minutes until everything is well combined.",
      "tip": "",
      "duration_mins": 2
    },
    {
      "step_no": 9,
      "instruction": "Remove from heat and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Chop beans evenly for uniform cooking.",
    "Do not add too much water — beans should retain a slight crunch.",
    "Fresh grated coconut gives the best taste.",
    "You can add a pinch of sugar or jaggery for mild sweetness (optional)."
