  "steps": [
    {
      "step_no": 1,
      "instruction": "Rinse moong dal and pressure cook with ¾ cup water and a pinch of turmeric for 2-3 whistles until soft. Mash lightly and set aside.",
      "tip": "",
      "duration_mins": 5
    },
    {
      "step_no": 2,
      "instruction": "Peel the bottle gourd, remove the seeds and chop into small cubes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "In a pan, add chopped sorakkai, turmeric powder, and little water. Cook covered until the vegetable becomes soft.",
      "tip": "",
      "duration_mins": 8
    },
    {
      "step_no": 4,
      "instruction": "Grind grated coconut, green chilli and cumin seeds into a smooth paste with little water.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add the cooked moong dal and ground coconut paste to the cooked sorakkai. Mix gently.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Add salt and simmer for 3-4 minutes until the kootu comes together. Adjust consistency with little hot water if needed.",
      "tip": "",
      "duration_mins": 4
    },
    {
      "step_no": 7,
      "instruction": "Heat oil in a small pan. Add mustard seeds and let them crackle.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Add urad dal and fry until golden. Add curry leaves and asafoetida. Pour the tempering over the kootu.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "Mix well and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Choose tender bottle gourd for better taste.",
    "Do not overcook the vegetable after adding dal to retain texture.",
    "You can replace moong dal with toor dal for a different flavour.",
    "This kootu thickens as it cools, so keep it slightly loose."
  ],
