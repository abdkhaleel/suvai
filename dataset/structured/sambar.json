  "steps": [
    {
      "step_no": 1,
      "instruction": "Wash toor dal and pressure cook with 2 cups water until soft and mushy (2-4 whistles). Mash well and set aside.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 2,
      "instruction": "While dal cooks, dry roast ingredients for sambar powder (red chilies, chana dal, urad dal, coriander seeds, fenugreek, cumin) and grind to a fine powder.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 3,
      "instruction": "Rinse and chop vegetables (shallots/onion, drumstick, okra, carrot, tomato).",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 4,
      "instruction": "Heat 1 tsp oil in a pot; sauté onions for 1 minute, add all vegetables and sauté for 2 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 5,
      "instruction": "Add 4 cups water and cook vegetables until tender.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 6,
      "instruction": "Soak tamarind in hot water, squeeze and extract juice (filter if needed).",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 7,
      "instruction": "Add turmeric powder, homemade sambar powder, salt, and tamarind water to the cooked vegetables; simmer for 3-5 minutes.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 8,
      "instruction": "Add mashed dal, mix well, adjust consistency with hot water if needed, and bring to a gentle boil. Add chopped coriander leaves.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 9,
      "instruction": "For tempering: Heat ghee/oil, add mustard seeds, cumin, fenugreek, red chilies, curry leaves, and asafoetida. Pour over the sambar.",
      "tip": "",
      "duration_mins": 0
    },
    {
      "step_no": 10,
      "instruction": "Simmer for 2-3 minutes and serve hot.",
      "tip": "",
      "duration_mins": 0
    }
  ],
  "tips": [
    "Use fresh homemade sambar powder for the best aroma and taste.",
    "Cook vegetables until soft so their flavors blend well into the stock.",
    "Add tamarind only after vegetables are cooked to ensure proper tenderness.",
    "For storage, refrigerate without tempering and add fresh tempering when reheating."
  ],
